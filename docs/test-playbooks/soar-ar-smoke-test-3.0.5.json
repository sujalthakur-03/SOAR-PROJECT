{
  "name": "SOAR AR Smoke Test 3.0.5",
  "description": "Live-fire validation of ADD-path Active Response actions against the 192.168.1.222 dev manager. Linux target: agent 005 (Agent-70). Windows target: agent 007 (RootSeeker). 5-step matrix — release/unlock paths were removed from SOAR's contract on 2026-05-14: isolate-host release uses Wazuh native <timeout> auto-expiry; disable-user unlock is a manual SOC operator task. Operator pre-creates 'soartest-linux' on 005 and 'soartest-win' on 007, spawns benign processes for kill_process steps. Manual dispatch only — not webhook-triggered.",
  "dsl": {
    "trigger_type": "manual",
    "severity": "medium",
    "shadow_mode": false,
    "tags": ["smoke-test", "active-response", "release-3.0.5"],
    "trigger": {
      "source": "manual",
      "severity_threshold": "medium"
    },
    "steps": [
      {
        "step_id": "step_01_linux_kill_process",
        "type": "action",
        "name": "Linux kill_process on agent 005 (Agent-70)",
        "connector_id": "cybersentinel_response",
        "action_type": "kill_process",
        "parameters": {
          "agent_id": "005",
          "process_name": "sleep"
        },
        "on_success": "step_02_linux_disable_user",
        "on_failure": "continue"
      },
      {
        "step_id": "step_02_linux_disable_user",
        "type": "action",
        "name": "Linux disable_user on agent 005",
        "connector_id": "cybersentinel_response",
        "action_type": "disable_user",
        "parameters": {
          "agent_id": "005",
          "username": "soartest-linux"
        },
        "on_success": "step_03_windows_kill_process",
        "on_failure": "continue"
      },
      {
        "step_id": "step_03_windows_kill_process",
        "type": "action",
        "name": "Windows kill_process on agent 007 (RootSeeker)",
        "connector_id": "cybersentinel_response",
        "action_type": "kill_process",
        "parameters": {
          "agent_id": "007",
          "process_name": "notepad"
        },
        "on_success": "step_04_windows_disable_user",
        "on_failure": "continue"
      },
      {
        "step_id": "step_04_windows_disable_user",
        "type": "action",
        "name": "Windows disable_user on agent 007",
        "connector_id": "cybersentinel_response",
        "action_type": "disable_user",
        "parameters": {
          "agent_id": "007",
          "username": "soartest-win"
        },
        "on_success": "step_05_linux_isolate_host",
        "on_failure": "continue"
      },
      {
        "step_id": "step_05_linux_isolate_host",
        "type": "action",
        "name": "Linux isolate_host on agent 005 (auto-release via manager <timeout>)",
        "connector_id": "cybersentinel_response",
        "action_type": "isolate_host",
        "parameters": {
          "agent_id": "005"
        },
        "on_success": "__END__",
        "on_failure": "stop"
      }
    ]
  }
}
