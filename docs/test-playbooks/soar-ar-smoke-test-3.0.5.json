{
  "name": "SOAR AR Smoke Test 3.0.5",
  "description": "Live-fire validation of Active Response actions against the 192.168.1.222 dev manager. Linux target: agent 005 (Agent-70). Windows kill/disable target: agent 007 (RootSeeker). Scope reduced to 8 steps — agent 056 (Windows isolate) is deferred until SOAR AR scripts are deployed there. Manual dispatch only — not webhook-triggered. Operator pre-creates throwaway user 'soartest-linux' on 005 + 'soartest-win' on 007, and spawns benign processes for the kill_process steps. PIDs are communicated by the manager-side operator at run time and entered as inputs before each kill_process step is dispatched.",
  "dsl": {
    "trigger_type": "manual",
    "severity": "medium",
    "shadow_mode": false,
    "tags": ["smoke-test", "active-response", "release-3.0.5"],
    "trigger": {
      "source": "manual",
      "severity_threshold": "medium"
    },
    "steps": [
      {
        "step_id": "step_01_linux_kill_process",
        "type": "action",
        "name": "Linux kill_process on agent 005 (Agent-70)",
        "connector_id": "cybersentinel_response",
        "action_type": "kill_process",
        "parameters": {
          "agent_id": "005",
          "process_name": "sleep"
        },
        "on_success": "step_02_linux_disable_user_lock",
        "on_failure": "continue"
      },
      {
        "step_id": "step_02_linux_disable_user_lock",
        "type": "action",
        "name": "Linux disable_user LOCK on agent 005",
        "connector_id": "cybersentinel_response",
        "action_type": "disable_user",
        "parameters": {
          "agent_id": "005",
          "username": "soartest-linux",
          "mode": "lock"
        },
        "on_success": "step_03_linux_disable_user_unlock",
        "on_failure": "continue"
      },
      {
        "step_id": "step_03_linux_disable_user_unlock",
        "type": "action",
        "name": "Linux disable_user UNLOCK on agent 005",
        "connector_id": "cybersentinel_response",
        "action_type": "disable_user",
        "parameters": {
          "agent_id": "005",
          "username": "soartest-linux",
          "mode": "unlock"
        },
        "on_success": "step_04_windows_kill_process",
        "on_failure": "continue"
      },
      {
        "step_id": "step_04_windows_kill_process",
        "type": "action",
        "name": "Windows kill_process on agent 007 (RootSeeker)",
        "connector_id": "cybersentinel_response",
        "action_type": "kill_process",
        "parameters": {
          "agent_id": "007",
          "process_name": "notepad"
        },
        "on_success": "step_05_windows_disable_user_lock",
        "on_failure": "continue"
      },
      {
        "step_id": "step_05_windows_disable_user_lock",
        "type": "action",
        "name": "Windows disable_user LOCK on agent 007",
        "connector_id": "cybersentinel_response",
        "action_type": "disable_user",
        "parameters": {
          "agent_id": "007",
          "username": "soartest-win",
          "mode": "lock"
        },
        "on_success": "step_06_windows_disable_user_unlock",
        "on_failure": "continue"
      },
      {
        "step_id": "step_06_windows_disable_user_unlock",
        "type": "action",
        "name": "Windows disable_user UNLOCK on agent 007",
        "connector_id": "cybersentinel_response",
        "action_type": "disable_user",
        "parameters": {
          "agent_id": "007",
          "username": "soartest-win",
          "mode": "unlock"
        },
        "on_success": "step_07_linux_isolate_host",
        "on_failure": "continue"
      },
      {
        "step_id": "step_07_linux_isolate_host",
        "type": "action",
        "name": "Linux isolate_host ADD on agent 005",
        "connector_id": "cybersentinel_response",
        "action_type": "isolate_host",
        "parameters": {
          "agent_id": "005",
          "mode": "isolate"
        },
        "on_success": "step_08_linux_isolate_host_release",
        "on_failure": "stop"
      },
      {
        "step_id": "step_08_linux_isolate_host_release",
        "type": "action",
        "name": "Linux isolate_host RELEASE on agent 005",
        "connector_id": "cybersentinel_response",
        "action_type": "isolate_host",
        "parameters": {
          "agent_id": "005",
          "mode": "release"
        },
        "on_success": "__END__",
        "on_failure": "stop"
      }
    ]
  }
}
