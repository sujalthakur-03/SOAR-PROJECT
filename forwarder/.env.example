# CyberSentinel Forwarder Environment Configuration
# ==================================================

# Alert Source Configuration
# --------------------------
# Path to the alert file or stream endpoint
ALERT_SOURCE=/var/ossec/logs/alerts/alerts.json

# Format of the alert source: json, jsonl, or ndjson
ALERT_FORMAT=json

# Routing Configuration
# ---------------------
# Path to the routing rules YAML file
ROUTING_RULES=routing_rules.yaml

# Offset Tracking
# ---------------
# File to store the current reading position (enables stateless restart)
OFFSET_FILE=.forwarder_offset

# Retry Configuration
# -------------------
# Maximum number of retry attempts for failed webhook calls
MAX_RETRIES=3

# Initial delay between retries (seconds)
RETRY_BASE_DELAY=1.0

# Maximum delay between retries (seconds)
RETRY_MAX_DELAY=30.0

# Concurrency
# -----------
# Maximum number of concurrent webhook requests
MAX_CONCURRENT=2

# Default timeout for webhook requests (seconds)
DEFAULT_TIMEOUT=30

# Security
# --------
# HMAC secret for signing webhook payloads (optional)
# If set, payloads will be signed with HMAC-SHA256
# HMAC_SECRET=your-secret-key-here

# Logging
# -------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# Performance
# -----------
# Interval between file checks when no new alerts (seconds)
POLL_INTERVAL=5

# Number of alerts to process per batch
BATCH_SIZE=5

# Dry-Run Mode
# ------------
# When enabled, forwarder evaluates routing rules and logs intended destinations
# but does NOT send HTTP requests or commit offset. Useful for rule testing.
FORWARDER_DRY_RUN=false

# SOAR Webhook Configuration
# --------------------------
# Base URL for the SOAR platform
SOAR_BASE_URL=http://192.168.1.122:3001

# Playbook IDs and Secrets (used in routing_rules.yaml)
